{
  "name": "@scrape/backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend — scraper, matcher, and API services",
  "type": "module",
  "scripts": {
    "dev": "node --import ./register.mjs --watch src/main.ts",
    "start": "node --import ./register.mjs src/main.ts",
    "scrape": "node --import ./register.mjs src/cli.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@scrape/database": "workspace:*",
    "@scrape/shared": "workspace:*",
    "bullmq": "^5.71.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.3",
    "@types/node": "^25.2.3",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  }
}
