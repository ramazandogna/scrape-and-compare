# ═══════════════════════════════════════════
# NestJS Backend — Server Ayarları
# ═══════════════════════════════════════════
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ═══════════════════════════════════════════
# PostgreSQL — Docker Compose ile çalışır
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://scrape:scrape_dev_2024@localhost:5432/scrape_db
POSTGRES_USER=scrape
POSTGRES_PASSWORD=scrape_dev_2024
POSTGRES_DB=scrape_db

# ═══════════════════════════════════════════
# Redis — BullMQ Kuyruk Motoru
# ═══════════════════════════════════════════
# BullMQ tüm queue state'ini Redis'te tutar.
# Docker Compose ile otomatik ayağa kalkar.
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══════════════════════════════════════════
# LinkedIn Scraper Configuration
# ═══════════════════════════════════════════
# Şu an login'siz public scrape yapıyoruz, ileride gerekirse:
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=

# Scraper Settings
HEADLESS=true
SLOW_MO=0
# Smart target — paginated search bu hedefe ulaşana kadar sayfa gezer
TARGET_NEW_JOBS_PER_KEYWORD=50
# LinkedIn rate limitini zorlamamak için tek scrape job'ında maksimum sayfa
MAX_SEARCH_PAGES_PER_KEYWORD=5
# Eski cap (geriye uyumluluk için tutuldu, default = TARGET_NEW_JOBS_PER_KEYWORD)
MAX_JOBS_PER_KEYWORD=50
REQUEST_DELAY_MIN=1000
REQUEST_DELAY_MAX=3000

# Arama Parametreleri
KEYWORDS=Frontend Developer,React Developer
LOCATION=Turkey

# Description Fetching
FETCH_DETAILS=true
MAX_DETAIL_FETCH=10

# Fast Scraper — Paralel Tab & Concurrency
PARALLEL_TABS=5
SEARCH_CONCURRENCY=2

# ═══════════════════════════════════════════
# Google Gemini — AI Scoring Engine
# ═══════════════════════════════════════════
# https://aistudio.google.com/app/apikey adresinden al
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# ═══════════════════════════════════════════
# Matcher — Batch Scoring Ayarları
# ═══════════════════════════════════════════
MATCHER_BATCH_SIZE=16
MATCHER_RATE_LIMIT=4
MATCHER_MIN_SCORE=50
