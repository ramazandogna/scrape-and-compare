// ═══════════════════════════════════════════════════════════
// Prisma Schema — PostgreSQL Database Definition
// ═══════════════════════════════════════════════════════════
//
// This file is the single source of truth for the database structure.
// prisma generate → emits the TypeScript client (type-safe queries)
// prisma migrate  → emits SQL migration files
//
// copilot-instructions rules:
// - Raw SQL forbidden, use the Prisma ORM
// - State Machine: via the ScraperAudit.status enum
// - @unique constraints: externalId, url
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  // pnpm strict isolation: .prisma/client stays inside the pnpm store,
  // and the VS Code TS server cannot resolve the symlink chain.
  // An explicit output keeps the generated client inside the project.
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

/// Currency — for salary normalization
enum SalaryCurrency {
  TRY
  USD
  EUR
}

/// Salary period — yearly or monthly
enum SalaryPeriod {
  MONTHLY
  YEARLY
}

/// Job listing source — which platform it came from
enum JobSource {
  LINKEDIN
  INDEED
  GLASSDOOR
}

/// Scraper State Machine — copilot-instructions rule #11
/// Explicit states instead of boolean flags. Valid transitions:
/// IDLE → SCANNING → EXTRACTING → COMPLETED
///                 ↘ FAILED     ↗ FAILED
///                   FAILED → IDLE
enum ScraperStatus {
  IDLE
  SCANNING
  EXTRACTING
  COMPLETED
  FAILED
}

// ─── TABLES ─────────────────────────────────────────────

/// User profile — CV parse output and preferences
model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String
  /// bcrypt hash — nullable for legacy seed users; auth-created users always set it
  passwordHash       String?
  /// Single-use reset token for the forgot-password flow
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  techStack          String[] /// Known technologies: ["React", "TypeScript", ...]
  experienceYears    Int      @default(0)
  preferredRoles     String[] /// ["Frontend Developer", "Fullstack Engineer"]
  preferredLocations String[] /// ["Istanbul", "Remote"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// User's match results
  matchResults MatchResult[]
  /// User's scrape sessions
  scraperAudits ScraperAudit[]
  /// Job listing access mappings available to the user
  userJobs UserJobListing[]

  @@map("users")
}

/// Job listing — enriched data coming from the scraper
model JobListing {
  id String @id @default(uuid())

  /// Original LinkedIn job ID — duplicate prevention
  externalId String @unique
  /// Direct listing link — duplicate prevention
  url String @unique

  title    String
  company  String
  logoUrl  String?
  location String

  /// Raw salary string (original from LinkedIn)
  salary String?
  /// Normalized salary range (in TRY/month)
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency SalaryCurrency?
  salaryPeriod   SalaryPeriod?

  /// Listing description (full text)
  description String? @db.Text
  /// Requirements list
  requirements String[]
  /// Extracted skills (JSON array: ExtractedSkill[])
  skills Json @default("[]")

  seniorityLevel String?
  employmentType String?
  /// Work mode: Remote, Hybrid, On-site
  workType       String?
  postedDate     String?

  /// Source platform
  source JobSource @default(LINKEDIN)
  /// When it was scraped
  scrapedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Match results for this listing
  matchResults MatchResult[]
  /// User access mappings
  userJobs UserJobListing[]

  @@map("job_listings")
}

/// Match result — score between a User and a JobListing
model MatchResult {
  id     String @id @default(uuid())

  /// Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)

  /// Match percentage in the 0-100 range
  score       Float
  /// AI-generated match rationale
  explanation String    @db.Text
  /// Matched skills
  matchedSkills  String[]
  /// Missing skills
  missingSkills  String[]

  createdAt DateTime @default(now())

  /// One match per user-job pair
  @@unique([userId, jobId])
  @@map("match_results")
}

/// Scraper audit record — log of each scrape session
model ScraperAudit {
  id String @id @default(uuid())

  /// User that triggered this scrape (nullable for legacy records)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// State Machine state
  status   ScraperStatus @default(IDLE)
  keyword  String
  location String

  /// Metrics
  totalFound     Int @default(0)
  totalExtracted Int @default(0)
  errorCount     Int @default(0)

  /// Error details (JSON array: ScraperError[])
  errorDetails Json?
  /// Total duration (milliseconds)
  durationMs Int @default(0)

  startedAt   DateTime @default(now())
  completedAt DateTime?

  /// Listings linked to the user during this scrape session
  userJobs UserJobListing[]

  @@index([userId, startedAt])
  @@map("scraper_audits")
}

/// Access mapping table between User and JobListing
model UserJobListing {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId String
  job   JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)

  auditId String?
  audit   ScraperAudit? @relation(fields: [auditId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId, createdAt])
  @@index([auditId])
  @@map("user_job_listings")
}
