# ═══════════════════════════════════════════
# PostgreSQL — Docker Compose ile çalışır
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://scrape:scrape_dev_2024@localhost:5432/scrape_db
POSTGRES_USER=scrape
POSTGRES_PASSWORD=scrape_dev_2024
POSTGRES_DB=scrape_db

# ═══════════════════════════════════════════
# LinkedIn Scraper Configuration
# ═══════════════════════════════════════════
# Şu an login'siz public scrape yapıyoruz, ileride gerekirse:
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=

# Scraper Settings
HEADLESS=true
SLOW_MO=0
MAX_JOBS_PER_KEYWORD=25
REQUEST_DELAY_MIN=1000
REQUEST_DELAY_MAX=3000

# Arama Parametreleri
KEYWORDS=Frontend Developer,React Developer
LOCATION=Turkey

# Description Fetching
FETCH_DETAILS=true
MAX_DETAIL_FETCH=10

# Fast Scraper — Paralel Tab
PARALLEL_TABS=5
