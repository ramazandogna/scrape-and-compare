{
  "name": "scrape-and-compare",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Driven Job Scraping & Matching Engine — Monorepo",
  "type": "module",
  "engines": {
    "pnpm": ">=9",
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @scrape/backend dev",
    "scrape": "pnpm --filter @scrape/backend scrape",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @scrape/database generate",
    "db:migrate": "pnpm --filter @scrape/database migrate",
    "db:studio": "pnpm --filter @scrape/database studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": ["scraper", "linkedin", "job-matching", "ai", "monorepo"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
