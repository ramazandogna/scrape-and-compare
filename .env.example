# ═══════════════════════════════════════════
# NestJS Backend — Server settings
# ═══════════════════════════════════════════
PORT=3000
CORS_ORIGIN=http://localhost:3001
# Auth — JWT signing secret, min 32 chars. Generate with `openssl rand -hex 32`.
JWT_SECRET=replace-me-with-32-plus-character-random-string-please
# The cookie 'secure' flag is enabled automatically when NODE_ENV=production.
NODE_ENV=development

# ═══════════════════════════════════════════
# PostgreSQL — runs via Docker Compose
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://scrape:scrape_dev_2024@localhost:5432/scrape_db
POSTGRES_USER=scrape
POSTGRES_PASSWORD=scrape_dev_2024
POSTGRES_DB=scrape_db

# ═══════════════════════════════════════════
# Redis — BullMQ queue engine
# ═══════════════════════════════════════════
# BullMQ keeps all queue state in Redis. Starts automatically via Docker Compose.
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══════════════════════════════════════════
# LinkedIn Scraper Configuration
# ═══════════════════════════════════════════
# Currently we scrape public listings without login. If needed later:
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=

# Scraper settings
# false = browser opens and is visible (debug). true = runs headless in background.
HEADLESS=true
SLOW_MO=0
# Smart target — paginated search browses pages until it reaches this target.
TARGET_NEW_JOBS_PER_KEYWORD=50
# Max pages per scrape job, to avoid hitting LinkedIn's rate limit (~25 listings/page).
MAX_SEARCH_PAGES_PER_KEYWORD=5
# Legacy cap (kept for backward compatibility, defaults to TARGET_NEW_JOBS_PER_KEYWORD).
MAX_JOBS_PER_KEYWORD=50
REQUEST_DELAY_MIN=1000
REQUEST_DELAY_MAX=3000

# Search parameters — comma-separated keywords
KEYWORDS=Frontend Developer,React Developer
LOCATION=Turkey

# Description fetching
# true = visit each listing's detail page to fetch its description (slower, richer)
# false = only read job-card data (faster)
FETCH_DETAILS=true
MAX_DETAIL_FETCH=10

# Fast scraper — parallel tabs & concurrency
# How many tabs open at once to fetch job details (too many will anger LinkedIn).
PARALLEL_TABS=5
# Number of keywords scanned concurrently during the search phase.
SEARCH_CONCURRENCY=2

# ═══════════════════════════════════════════
# Google Gemini — AI scoring engine
# ═══════════════════════════════════════════
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# Kicks in only when the quota is exhausted (429 quota / resource exhausted).
GEMINI_QUOTA_FALLBACK_MODEL=gemini-2.5-flash-lite
# If the primary model returns 503, switch to the fallback quickly.
GEMINI_PRIMARY_503_RETRIES=1
# 503 resilience for the fallback model.
GEMINI_FALLBACK_503_RETRIES=2

# ═══════════════════════════════════════════
# Matcher — Batch scoring settings
# ═══════════════════════════════════════════
MATCHER_BATCH_SIZE=16
MATCHER_RATE_LIMIT=4
MATCHER_MIN_SCORE=50
